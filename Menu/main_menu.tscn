[sub_resource type="GDScript" id="GDScript_turts"]
script/source = "extends CanvasLayer

const UPGRADE_SCENE_PATH_TEMPLATE := \"res://Menu/Upgrades/tower_%s_upgrades.tscn\"
const CARD_BUTTON_NAME := \"CardButton\"

@onready var upgrades_tree: CanvasLayer = get_parent().get_node_or_null(\"UpgradeTrees\")

var current_upgrade_instance: Node

func _ready() -> void:
	_setup_card_buttons()
	_connect_existing_back_button()
	show_tower_cards()
	
func _setup_card_buttons() -> void:
	for child in get_children():
		if child is Control and child.name.is_valid_int():
			_setup_card_button(child)
			
func _setup_card_button(card: Control) -> void:
	var button := card.get_node_or_null(CARD_BUTTON_NAME) as TextureButton
	if button == null:
		button = TextureButton.new()
		button.name = CARD_BUTTON_NAME
		button.set_anchors_preset(Control.PRESET_FULL_RECT)
		card.add_child(button)
		for node in card.get_children():
			if node != button: node.reparent(button, true)
	if not button.pressed.is_connected(_on_card_pressed):
		button.pressed.connect(_on_card_pressed.bind(card))
		
func _on_card_pressed(card: Control) -> void:
	_open_tower_upgrades(card)
	
func _open_tower_upgrades(card: Control) -> void:
	if upgrades_tree:
		upgrades_tree.show()
		var turt_parent = upgrades_tree.get_node_or_null(\"Turt\")
		if turt_parent:
			for i in range(1, 13):
				var sprite = turt_parent.get_node_or_null(str(i))
				if sprite:
					sprite.visible = (str(i) == card.name)
		var card_button = card.get_node_or_null(\"CardButton\")
		var orig_label = card_button.get_node_or_null(\"NameLabel\") if card_button else null
		var turt_label = upgrades_tree.get_node_or_null(\"Turt/NameLabel\")
		if turt_label and orig_label:
			turt_label.text = orig_label.text
			upgrades_tree.load_tower_data(orig_label.text)
	var scene_path := UPGRADE_SCENE_PATH_TEMPLATE % card.name
	var packed_scene := load(scene_path)
	if packed_scene is PackedScene:
		_clear_current_upgrade()
		current_upgrade_instance = packed_scene.instantiate()
		if upgrades_tree:
			upgrades_tree.add_child(current_upgrade_instance)
	hide()
	if upgrades_tree: upgrades_tree.show()
	
func _clear_current_upgrade() -> void:
	if current_upgrade_instance:
		current_upgrade_instance.queue_free()
		current_upgrade_instance = null
		
func _on_back_pressed() -> void:
	show_tower_cards()
	
func show_tower_cards() -> void:
	if upgrades_tree:
		upgrades_tree.hide()
		if upgrades_tree.has_method(\"reset_upgrades\"):
			upgrades_tree.reset_upgrades()
	show()
	_clear_current_upgrade()
	
func close_upgrades_if_open() -> bool:
	if upgrades_tree and upgrades_tree.visible:
		show_tower_cards()
		return true
	return false
	
func _connect_existing_back_button() -> void:
	var back_btn = get_parent().get_node_or_null(\"BackButton\")
	if back_btn and not back_btn.pressed.is_connected(_on_back_pressed):
		back_btn.pressed.connect(_on_back_pressed)
"

